---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import { Clock9, ArrowRight, Shield, Target, Zap, Users, CheckCircle2, XCircle, Menu, X } from '@lucide/astro';
---

<Layout>
  <!-- Navigation -->
  <nav data-scrolled="false" class="fixed top-0 w-full z-50 transition-all duration-300">
    <div class="max-w-6xl mx-auto px-6 flex justify-between items-center">
      <div class="flex items-center gap-2 cursor-pointer" data-scroll-to="top">
        <div class="w-8 h-8 bg-white flex items-center justify-center rounded-xs">
          <Clock9 class="text-black w-5 h-5" />
        </div>
        <span class="text-xl font-semibold tracking-tight text-white uppercase italic">9th Hour</span>
      </div>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        <button data-scroll-to="problem" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">The Problem</button>
        <button data-scroll-to="solution" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">What I Do</button>
        <button data-scroll-to="process" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">Process</button>
        <button data-scroll-to="about" class="text-sm font-medium text-zinc-400 hover:text-white transition-colors">About</button>
        <button data-scroll-to="cta" class="bg-zinc-100 text-black px-5 py-2 rounded-full text-sm font-semibold hover:bg-white transition-all">Inquire</button>
      </div>

      <!-- Mobile Menu Toggle -->
      <button id="mobile-menu-toggle" class="md:hidden text-white">
        <Menu id="menu-icon-open" class="w-6 h-6" />
        <X id="menu-icon-close" class="w-6 h-6 hidden" />
      </button>
    </div>

    <!-- Mobile Nav Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-black z-40 flex-col items-center justify-center gap-8 text-2xl hidden">
      <button data-scroll-to="problem" class="font-light">The Problem</button>
      <button data-scroll-to="solution" class="font-light">What I Do</button>
      <button data-scroll-to="process" class="font-light">Process</button>
      <button data-scroll-to="about" class="font-light">About</button>
      <button data-scroll-to="cta" class="bg-white text-black px-8 py-3 rounded-full text-lg font-bold">Inquire</button>
    </div>
  </nav>

  <main>
    <!-- 1. Hero Section -->
    <section class="pt-40 pb-24 md:pt-60 md:pb-40 px-6">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-5xl md:text-7xl font-bold text-white tracking-tight leading-[1.1] mb-8">
          The product is built. <br />
          <span class="text-zinc-500 italic">Now it needs to work.</span>
        </h1>
        <div class="grid md:grid-cols-2 gap-12">
          <div>
            <p class="text-xl md:text-2xl text-zinc-400 font-medium leading-relaxed">
              Temporary technical and product ownership for B2B software teams.
            </p>
          </div>
          <div>
            <p class="text-lg text-zinc-500 leading-relaxed">
              9th Hour is a personal studio for founders and teams who have successfully launched, but have lost the ability to move with confidence. I step in to resolve technical debt, clarify priorities, and restore a culture of predictable delivery.
            </p>
            <button
              data-scroll-to="problem"
              class="mt-8 flex items-center gap-2 text-white font-semibold group border-b border-white/20 pb-1 hover:border-white transition-all"
            >
              Read the mission <ArrowRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. The Problem -->
    <section id="problem" class="py-24 md:py-40 px-6 border-t border-white/5 bg-[#0d0d0d]">
      <div class="max-w-4xl mx-auto">
        <span class="text-xs uppercase tracking-[0.2em] text-zinc-500 font-bold mb-4 block">The Context</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-12 tracking-tight">The weight of a working product.</h2>
        <div class="prose prose-invert max-w-none">
          <p class="text-xl text-zinc-400 mb-12 leading-relaxed">
            There is a specific point in a software product's life where the original momentum stalls. You have real users and real revenue, but development has become a source of friction rather than a lever for progress.
          </p>

          <div class="grid sm:grid-cols-2 gap-8">
            <div class="flex gap-4 items-start p-6 bg-white/5 rounded-xl border border-white/5">
              <div class="mt-1 flex-shrink-0 w-2 h-2 rounded-full bg-zinc-600"></div>
              <p class="text-zinc-300">Features take longer to ship than they used to.</p>
            </div>
            <div class="flex gap-4 items-start p-6 bg-white/5 rounded-xl border border-white/5">
              <div class="mt-1 flex-shrink-0 w-2 h-2 rounded-full bg-zinc-600"></div>
              <p class="text-zinc-300">The roadmap is a collection of guesses rather than a strategy.</p>
            </div>
            <div class="flex gap-4 items-start p-6 bg-white/5 rounded-xl border border-white/5">
              <div class="mt-1 flex-shrink-0 w-2 h-2 rounded-full bg-zinc-600"></div>
              <p class="text-zinc-300">Decision fatigue is slowing down the founders and the engineering team.</p>
            </div>
            <div class="flex gap-4 items-start p-6 bg-white/5 rounded-xl border border-white/5">
              <div class="mt-1 flex-shrink-0 w-2 h-2 rounded-full bg-zinc-600"></div>
              <p class="text-zinc-300">The introduction of AI or new modules feels aimless and reactionary.</p>
            </div>
          </div>

          <div class="mt-16 p-8 border-l-2 border-zinc-700 italic">
            <p class="text-2xl text-zinc-300">
              "You don't need more developers. You need a clear path and the authority to take it."
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. What 9th Hour Does -->
    <section id="solution" class="py-24 md:py-40 px-6 border-t border-white/5">
      <div class="max-w-4xl mx-auto">
        <span class="text-xs uppercase tracking-[0.2em] text-zinc-500 font-bold mb-4 block">The Role</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-8 tracking-tight">Temporary ownership, permanent clarity.</h2>
        <p class="text-xl text-zinc-400 mb-16 leading-relaxed">
          I do not act as an advisor or a consultant who leaves you with a document. I act as a temporary technical and product owner. I take responsibility for the difficult decisions that have been deferred.
        </p>

        <div class="grid gap-px bg-white/10 overflow-hidden border border-white/10 rounded-2xl">
          <div class="bg-[#0a0a0a] p-8 flex flex-col md:flex-row md:items-center gap-6 group hover:bg-zinc-900 transition-colors">
            <div class="w-12 h-12 flex items-center justify-center bg-zinc-800 rounded-lg text-zinc-400 group-hover:text-white transition-colors">
              <Shield />
            </div>
            <div>
              <h3 class="text-xl font-bold text-white mb-1">Establish Structure</h3>
              <p class="text-zinc-500 group-hover:text-zinc-400 transition-colors">Implement the discipline required to turn 'messy' into 'maintainable.'</p>
            </div>
          </div>
          <div class="bg-[#0a0a0a] p-8 flex flex-col md:flex-row md:items-center gap-6 group hover:bg-zinc-900 transition-colors">
            <div class="w-12 h-12 flex items-center justify-center bg-zinc-800 rounded-lg text-zinc-400 group-hover:text-white transition-colors">
              <Target />
            </div>
            <div>
              <h3 class="text-xl font-bold text-white mb-1">Drive Decisions</h3>
              <p class="text-zinc-500 group-hover:text-zinc-400 transition-colors">Remove the bottleneck of uncertainty by making technical and product trade-offs with confidence.</p>
            </div>
          </div>
          <div class="bg-[#0a0a0a] p-8 flex flex-col md:flex-row md:items-center gap-6 group hover:bg-zinc-900 transition-colors">
            <div class="w-12 h-12 flex items-center justify-center bg-zinc-800 rounded-lg text-zinc-400 group-hover:text-white transition-colors">
              <Zap />
            </div>
            <div>
              <h3 class="text-xl font-bold text-white mb-1">Restore Calm</h3>
              <p class="text-zinc-500 group-hover:text-zinc-400 transition-colors">Replace the anxiety of the unknown with a steady, predictable rhythm of shipping.</p>
            </div>
          </div>
          <div class="bg-[#0a0a0a] p-8 flex flex-col md:flex-row md:items-center gap-6 group hover:bg-zinc-900 transition-colors">
            <div class="w-12 h-12 flex items-center justify-center bg-zinc-800 rounded-lg text-zinc-400 group-hover:text-white transition-colors">
              <Users />
            </div>
            <div>
              <h3 class="text-xl font-bold text-white mb-1">Bridge the Gap</h3>
              <p class="text-zinc-500 group-hover:text-zinc-400 transition-colors">Align the business goals of the founders with the technical realities of the code.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. The Process -->
    <section id="process" class="py-24 md:py-40 px-6 border-t border-white/5 bg-[#0d0d0d]">
      <div class="max-w-4xl mx-auto">
        <span class="text-xs uppercase tracking-[0.2em] text-zinc-500 font-bold mb-4 block">The Roadmap</span>
        <h2 class="text-4xl md:text-5xl font-bold text-white mb-16 tracking-tight">A deliberate path toward stability.</h2>

        <div class="space-y-12 relative before:absolute before:left-8 before:top-0 before:bottom-0 before:w-px before:bg-white/10 md:before:left-1/2 md:before:-translate-x-px">
          <!-- Step 01 -->
          <div class="relative flex items-center gap-12 md:justify-between md:flex-row">
            <div class="absolute left-[31px] md:left-1/2 md:-translate-x-1/2 w-3 h-3 bg-zinc-800 border border-zinc-600 rounded-full z-10"></div>
            <div class="pl-16 md:pl-0 md:w-[45%]">
              <div class="flex items-center gap-4 mb-2">
                <span class="text-xs font-mono text-zinc-600">01</span>
                <h3 class="text-2xl font-bold text-white">Clarity</h3>
              </div>
              <p class="text-zinc-500 leading-relaxed">An immediate audit of the current technical state, team dynamics, and product bottlenecks. We identify exactly why progress has slowed.</p>
            </div>
            <div class="hidden md:block md:w-[45%]"></div>
          </div>
          <!-- Step 02 -->
          <div class="relative flex items-center gap-12 md:justify-between md:flex-row-reverse">
            <div class="absolute left-[31px] md:left-1/2 md:-translate-x-1/2 w-3 h-3 bg-zinc-800 border border-zinc-600 rounded-full z-10"></div>
            <div class="pl-16 md:pl-0 md:w-[45%]">
              <div class="flex items-center gap-4 mb-2">
                <span class="text-xs font-mono text-zinc-600">02</span>
                <h3 class="text-2xl font-bold text-white">Direction</h3>
              </div>
              <p class="text-zinc-500 leading-relaxed">We define a focused roadmap. We stop doing the things that don't matter and commit to the few things that do.</p>
            </div>
            <div class="hidden md:block md:w-[45%]"></div>
          </div>
          <!-- Step 03 -->
          <div class="relative flex items-center gap-12 md:justify-between md:flex-row">
            <div class="absolute left-[31px] md:left-1/2 md:-translate-x-1/2 w-3 h-3 bg-zinc-800 border border-zinc-600 rounded-full z-10"></div>
            <div class="pl-16 md:pl-0 md:w-[45%]">
              <div class="flex items-center gap-4 mb-2">
                <span class="text-xs font-mono text-zinc-600">03</span>
                <h3 class="text-2xl font-bold text-white">Delivery</h3>
              </div>
              <p class="text-zinc-500 leading-relaxed">I lead the team through the execution phase, resolving technical debt and shipping critical updates to prove the new rhythm works.</p>
            </div>
            <div class="hidden md:block md:w-[45%]"></div>
          </div>
          <!-- Step 04 -->
          <div class="relative flex items-center gap-12 md:justify-between md:flex-row-reverse">
            <div class="absolute left-[31px] md:left-1/2 md:-translate-x-1/2 w-3 h-3 bg-zinc-800 border border-zinc-600 rounded-full z-10"></div>
            <div class="pl-16 md:pl-0 md:w-[45%]">
              <div class="flex items-center gap-4 mb-2">
                <span class="text-xs font-mono text-zinc-600">04</span>
                <h3 class="text-2xl font-bold text-white">Handover</h3>
              </div>
              <p class="text-zinc-500 leading-relaxed">Once the product is stable and the team is aligned, I prepare the environment for your long-term technical leadership and step away.</p>
            </div>
            <div class="hidden md:block md:w-[45%]"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- 5. What 9th Hour Is / Is Not -->
    <section class="py-24 md:py-40 px-6 border-t border-white/5">
      <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
            <CheckCircle2 class="text-emerald-500" /> 9th Hour Is
          </h3>
          <ul class="space-y-4">
            <li class="text-zinc-400 pb-4 border-b border-white/5">One senior engineer taking full responsibility.</li>
            <li class="text-zinc-400 pb-4 border-b border-white/5">A temporary intervention (3–9 months).</li>
            <li class="text-zinc-400 pb-4 border-b border-white/5">Focused on discipline and craftsmanship.</li>
            <li class="text-zinc-400 pb-4 border-b border-white/5">Direct, honest, and decisive.</li>
          </ul>
        </div>
        <div>
          <h3 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
            <XCircle class="text-rose-500" /> 9th Hour Is Not
          </h3>
          <ul class="space-y-4">
            <li class="text-zinc-400 pb-4 border-b border-white/5">An agency looking to bill hours.</li>
            <li class="text-zinc-400 pb-4 border-b border-white/5">A recruitment or body-leasing service.</li>
            <li class="text-zinc-400 pb-4 border-b border-white/5">A source of generic 'advice.'</li>
            <li class="text-zinc-400 pb-4 border-b border-white/5">A permanent hire.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- 6. Who This Is For -->
    <section class="py-24 md:py-40 px-6 border-t border-white/5 bg-white text-black">
      <div class="max-w-4xl mx-auto">
        <span class="text-xs uppercase tracking-[0.2em] text-zinc-400 font-bold mb-4 block">The Ideal Match</span>
        <h2 class="text-4xl md:text-5xl font-bold mb-8 tracking-tight">For products with real complexity.</h2>
        <p class="text-xl text-zinc-600 mb-12">
          This studio is designed for B2B founders and product owners who manage teams of 5 to 20 people.
        </p>

        <div class="grid sm:grid-cols-2 gap-px bg-black/10">
          <div class="bg-white p-8 flex items-start gap-4">
            <div class="w-1.5 h-1.5 rounded-full bg-black mt-2.5 flex-shrink-0"></div>
            <p class="text-lg font-medium text-zinc-900">Your product has an established user base and revenue.</p>
          </div>
          <div class="bg-white p-8 flex items-start gap-4">
            <div class="w-1.5 h-1.5 rounded-full bg-black mt-2.5 flex-shrink-0"></div>
            <p class="text-lg font-medium text-zinc-900">The technical foundation feels fragile or overwhelming.</p>
          </div>
          <div class="bg-white p-8 flex items-start gap-4">
            <div class="w-1.5 h-1.5 rounded-full bg-black mt-2.5 flex-shrink-0"></div>
            <p class="text-lg font-medium text-zinc-900">You feel like you are losing the 'big picture' to daily fires.</p>
          </div>
          <div class="bg-white p-8 flex items-start gap-4">
            <div class="w-1.5 h-1.5 rounded-full bg-black mt-2.5 flex-shrink-0"></div>
            <p class="text-lg font-medium text-zinc-900">You value professional maturity over temporary hype.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 7. About -->
    <section id="about" class="py-24 md:py-40 px-6 border-t border-white/5">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row gap-16 items-start">
          <div class="flex-shrink-0">
            <div class="w-24 h-24 rounded-2xl bg-gradient-to-br from-zinc-700 to-zinc-900 flex items-center justify-center border border-white/10 overflow-hidden shadow-2xl">
              <Clock9 class="w-12 h-12 text-zinc-500" />
            </div>
          </div>
          <div>
            <span class="text-xs uppercase tracking-[0.2em] text-zinc-500 font-bold mb-4 block">The Principal</span>
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-8 tracking-tight">A discipline of delivery.</h2>
            <div class="prose prose-invert prose-lg text-zinc-400 space-y-6">
              <p>
                9th Hour is run by a senior software engineer with a career built on responsibility. I have seen how quickly software can become a burden when it lacks a steady hand.
              </p>
              <p>
                I value quiet competence, long-term thinking, and the relief that comes from a well-ordered system. I don't believe in "moving fast and breaking things"—I believe in moving steadily so that things stay fixed.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 8. Call to Action -->
    <section id="cta" class="py-24 md:py-40 px-6 bg-[#111] border-t border-white/5">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl md:text-6xl font-bold text-white mb-8 tracking-tighter">Start a conversation.</h2>
        <p class="text-xl text-zinc-400 mb-12 max-w-2xl mx-auto leading-relaxed">
          If your product development no longer feels under your control, let's discuss the current state of your project. No sales pitch, just a professional evaluation of whether I can help you regain your momentum.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <button class="bg-white text-black px-10 py-4 rounded-full text-lg font-bold hover:bg-zinc-200 transition-all flex items-center gap-2 group">
            Inquire about availability <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
          </button>
          <p class="text-zinc-500 text-sm">Typical response within 24 hours.</p>
        </div>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
      <div class="flex items-center gap-2 opacity-50 grayscale hover:grayscale-0 transition-all">
        <Clock9 class="w-5 h-5 text-white" />
        <span class="text-sm font-semibold text-white tracking-widest uppercase italic">9th Hour</span>
      </div>
      <p class="text-zinc-600 text-xs tracking-widest uppercase">
        &copy; {new Date().getFullYear()} 9th Hour Studio. No cookies. No tracking.
      </p>
      <div class="flex gap-6 text-zinc-500 text-sm font-medium">
        <span class="cursor-pointer hover:text-white transition-colors">LinkedIn</span>
        <span class="cursor-pointer hover:text-white transition-colors">Email</span>
      </div>
    </div>
  </footer>

  <script>
    // 1. Scroll nav — toggle data-scrolled attribute
    const nav = document.querySelector('nav');
    function updateNav() {
      if (nav) {
        nav.setAttribute('data-scrolled', window.scrollY > 20 ? 'true' : 'false');
      }
    }
    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();

    // 2. Mobile menu toggle
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    menuToggle?.addEventListener('click', () => {
      const isOpen = !mobileMenu?.classList.contains('hidden');
      if (isOpen) {
        mobileMenu?.classList.add('hidden');
        mobileMenu?.classList.remove('flex', 'mobile-menu-enter');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
      } else {
        mobileMenu?.classList.remove('hidden');
        mobileMenu?.classList.add('flex', 'mobile-menu-enter');
        iconOpen?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
      }
    });

    // 3. Smooth scroll for all [data-scroll-to] elements
    document.querySelectorAll('[data-scroll-to]').forEach((el) => {
      el.addEventListener('click', () => {
        const targetId = el.getAttribute('data-scroll-to');

        // Close mobile menu if open
        mobileMenu?.classList.add('hidden');
        mobileMenu?.classList.remove('flex', 'mobile-menu-enter');
        iconOpen?.classList.remove('hidden');
        iconClose?.classList.add('hidden');

        if (targetId === 'top') {
          window.scrollTo({ top: 0, behavior: 'smooth' });
          return;
        }

        const target = document.getElementById(targetId!);
        if (target) {
          const offset = 80;
          const bodyRect = document.body.getBoundingClientRect().top;
          const elementRect = target.getBoundingClientRect().top;
          const elementPosition = elementRect - bodyRect;
          const offsetPosition = elementPosition - offset;

          window.scrollTo({
            top: offsetPosition,
            behavior: 'smooth',
          });
        }
      });
    });
  </script>
</Layout>
