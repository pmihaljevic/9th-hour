---
import { Clock9 } from "@lucide/astro";
---

<footer class="py-12 px-6 border-t border-gray-200 dark:border-white/5">
  <div
    class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8"
  >
    <div
      class="flex items-center gap-2 opacity-50 grayscale hover:grayscale-0 transition-all"
    >
      <Clock9 class="w-5 h-5 text-gray-900 dark:text-white" />
      <span
        class="text-sm font-semibold text-gray-900 dark:text-white tracking-widest uppercase italic"
        >9th Hour</span
      >
    </div>
    <p
      class="text-gray-500 dark:text-zinc-600 text-xs tracking-widest uppercase"
    >
      &copy; {new Date().getFullYear()} 9th Hour Studio. No cookies. No tracking.
    </p>
    <div
      class="flex gap-6 text-gray-500 dark:text-zinc-500 text-sm font-medium"
    >
      <!-- <span
        class="cursor-pointer hover:text-gray-900 dark:hover:text-white transition-colors"
        >LinkedIn</span
      >
      <span
        class="cursor-pointer hover:text-gray-900 dark:hover:text-white transition-colors"
        >Email</span
      > -->
    </div>
  </div>
</footer>
