---
import { Clock9, Menu, X, Sun, Moon } from "@lucide/astro";
import { getCollection } from "astro:content";

interface Props {
  isHome?: boolean;
}

const { isHome = false } = Astro.props;
const base = import.meta.env.BASE_URL;

const now = new Date();
const sevenDaysAgo = new Date(now.getTime() - 7 * 24 * 60 * 60 * 1000);
const posts = await getCollection("field-notes");
const hasRecentPost = posts.some(
  (post) => !post.data.draft && post.data.publishedAt >= sevenDaysAgo,
);
---

<nav
  data-scrolled="false"
  class="fixed top-0 w-full z-50 transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-6 flex justify-between items-center">
    {
      isHome ? (
        <div
          class="flex items-center gap-2 cursor-pointer"
          data-scroll-to="top"
        >
          <div class="w-8 h-8 bg-gray-900 dark:bg-white flex items-center justify-center rounded-xs">
            <Clock9 class="text-white dark:text-black w-5 h-5" />
          </div>
          <span class="text-xl font-semibold tracking-tight text-gray-900 dark:text-white uppercase italic">
            9th Hour
          </span>
        </div>
      ) : (
        <a href={base} class="flex items-center gap-2">
          <div class="w-8 h-8 bg-gray-900 dark:bg-white flex items-center justify-center rounded-xs">
            <Clock9 class="text-white dark:text-black w-5 h-5" />
          </div>
          <span class="text-xl font-semibold tracking-tight text-gray-900 dark:text-white uppercase italic">
            9th Hour
          </span>
        </a>
      )
    }

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-8">
      {
        isHome ? (
          <>
            <button
              data-scroll-to="problem"
              class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-zinc-400 dark:hover:text-white transition-colors"
            >
              The Problem
            </button>
            <button
              data-scroll-to="engagement"
              class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-zinc-400 dark:hover:text-white transition-colors"
            >
              How I Work
            </button>
            <button
              data-scroll-to="process"
              class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-zinc-400 dark:hover:text-white transition-colors"
            >
              Process
            </button>
            <button
              data-scroll-to="about"
              class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-zinc-400 dark:hover:text-white transition-colors"
            >
              About
            </button>
          </>
        ) : (
          <>
            <a
              href={`${base}#problem`}
              class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-zinc-400 dark:hover:text-white transition-colors"
            >
              The Problem
            </a>
            <a
              href={`${base}#engagement`}
              class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-zinc-400 dark:hover:text-white transition-colors"
            >
              How I Work
            </a>
            <a
              href={`${base}#process`}
              class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-zinc-400 dark:hover:text-white transition-colors"
            >
              Process
            </a>
            <a
              href={`${base}#about`}
              class="text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-zinc-400 dark:hover:text-white transition-colors"
            >
              About
            </a>
          </>
        )
      }
      <a
        href={`${base}/field-notes/`}
        class="relative text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-zinc-400 dark:hover:text-white transition-colors"
      >
        Field Notes
        {
          hasRecentPost && (
            <span class="absolute -top-1 -right-2.5 flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-gray-900 dark:bg-white opacity-75" />
              <span class="relative inline-flex rounded-full h-2 w-2 bg-gray-900 dark:bg-white" />
            </span>
          )
        }
      </a>
      <button
        id="theme-toggle-desktop"
        class="p-2 rounded-lg bg-gray-100 dark:bg-zinc-800 text-gray-600 dark:text-zinc-400 hover:bg-gray-200 dark:hover:bg-zinc-700 transition-colors"
        aria-label="Toggle theme"
      >
        <Sun class="w-5 h-5 hidden dark:block" />
        <Moon class="w-5 h-5 block dark:hidden" />
      </button>
      {
        isHome ? (
          <button
            data-scroll-to="cta"
            class="bg-gray-900 text-white dark:bg-zinc-100 dark:text-black px-5 py-2 rounded-full text-sm font-semibold hover:bg-black dark:hover:bg-white transition-all"
          >
            Inquire
          </button>
        ) : (
          <a
            href={`${base}#cta`}
            class="bg-gray-900 text-white dark:bg-zinc-100 dark:text-black px-5 py-2 rounded-full text-sm font-semibold hover:bg-black dark:hover:bg-white transition-all"
          >
            Inquire
          </a>
        )
      }
    </div>

    <!-- Mobile Menu Toggle -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden text-gray-900 dark:text-white"
    >
      <Menu id="menu-icon-open" class="w-6 h-6" />
      <X id="menu-icon-close" class="w-6 h-6 hidden" />
    </button>
  </div>

  <!-- Mobile Nav Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white dark:bg-black z-40 flex-col items-center justify-center gap-8 text-2xl hidden text-gray-900 dark:text-white"
  >
    {
      isHome ? (
        <>
          <button data-scroll-to="problem" class="font-light">
            The Problem
          </button>
          <button data-scroll-to="engagement" class="font-light">
            How I Work
          </button>
          <button data-scroll-to="process" class="font-light">
            Process
          </button>
          <button data-scroll-to="about" class="font-light">
            About
          </button>
        </>
      ) : (
        <>
          <a href={`${base}#problem`} class="font-light">
            The Problem
          </a>
          <a href={`${base}#engagement`} class="font-light">
            How I Work
          </a>
          <a href={`${base}#process`} class="font-light">
            Process
          </a>
          <a href={`${base}#about`} class="font-light">
            About
          </a>
        </>
      )
    }
    <a href={`${base}/field-notes/`} class="relative font-light">
      Field Notes
      {
        hasRecentPost && (
          <span class="absolute -top-1 -right-3 flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-gray-900 dark:bg-white opacity-75" />
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-gray-900 dark:bg-white" />
          </span>
        )
      }
    </a>
    <button
      id="theme-toggle-mobile"
      class="p-3 rounded-full bg-gray-100 dark:bg-zinc-800 text-gray-600 dark:text-zinc-400"
      aria-label="Toggle theme"
    >
      <Sun class="w-6 h-6 hidden dark:block" />
      <Moon class="w-6 h-6 block dark:hidden" />
    </button>
    {
      isHome ? (
        <button
          data-scroll-to="cta"
          class="bg-gray-900 text-white dark:bg-white dark:text-black px-8 py-3 rounded-full text-lg font-bold"
        >
          Inquire
        </button>
      ) : (
        <a
          href={`${base}#cta`}
          class="bg-gray-900 text-white dark:bg-white dark:text-black px-8 py-3 rounded-full text-lg font-bold"
        >
          Inquire
        </a>
      )
    }
  </div>
</nav>

<script>
  // Scroll nav — toggle data-scrolled attribute
  const nav = document.querySelector("nav");
  function updateNav() {
    if (nav) {
      nav.setAttribute("data-scrolled", window.scrollY > 20 ? "true" : "false");
    }
  }
  window.addEventListener("scroll", updateNav, { passive: true });
  updateNav();

  // Mobile menu toggle
  const menuToggle = document.getElementById("mobile-menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const iconOpen = document.getElementById("menu-icon-open");
  const iconClose = document.getElementById("menu-icon-close");

  menuToggle?.addEventListener("click", () => {
    const isOpen = !mobileMenu?.classList.contains("hidden");
    if (isOpen) {
      mobileMenu?.classList.add("hidden");
      mobileMenu?.classList.remove("flex", "mobile-menu-enter");
      iconOpen?.classList.remove("hidden");
      iconClose?.classList.add("hidden");
    } else {
      mobileMenu?.classList.remove("hidden");
      mobileMenu?.classList.add("flex", "mobile-menu-enter");
      iconOpen?.classList.add("hidden");
      iconClose?.classList.remove("hidden");
    }
  });

  // Theme Toggle
  function toggleTheme() {
    const isDark = document.documentElement.classList.toggle("dark");
    localStorage.setItem("theme", isDark ? "dark" : "light");
  }

  document
    .getElementById("theme-toggle-desktop")
    ?.addEventListener("click", toggleTheme);
  document
    .getElementById("theme-toggle-mobile")
    ?.addEventListener("click", toggleTheme);

  // Listen for system preference changes
  window
    .matchMedia("(prefers-color-scheme: dark)")
    .addEventListener("change", (e) => {
      if (!localStorage.getItem("theme")) {
        document.documentElement.classList.toggle("dark", e.matches);
      }
    });
</script>
