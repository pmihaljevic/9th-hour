---
import { X, CheckCircle2, XCircle } from "@lucide/astro";
---

<div
  id="contact-modal"
  class="fixed inset-0 z-[100] hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="contact-modal-title"
>
  <!-- Backdrop -->
  <div
    id="contact-modal-backdrop"
    class="absolute inset-0 bg-black/50 dark:bg-black/70 backdrop-blur-sm"
  >
  </div>

  <!-- Modal panel -->
  <div class="relative flex items-center justify-center min-h-dvh p-4">
    <div
      id="contact-modal-panel"
      class="relative w-full max-w-lg max-h-[90dvh] overflow-y-auto bg-white dark:bg-[#141414] rounded-2xl shadow-2xl border border-gray-200 dark:border-white/10"
    >
      <!-- Header -->
      <div class="flex items-center justify-between p-6 pb-0">
        <h2
          id="contact-modal-title"
          class="text-2xl font-bold text-gray-900 dark:text-white tracking-tight"
        >
          Describe your situation
        </h2>
        <button
          id="contact-modal-close"
          class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-zinc-800 transition-colors"
          aria-label="Close dialog"
        >
          <X class="w-5 h-5 text-gray-500 dark:text-zinc-400" />
        </button>
      </div>

      <!-- Form -->
      <form id="contact-form" class="p-6 space-y-5">
        <!-- Honeypot (Web3Forms spam protection) -->
        <input
          type="checkbox"
          name="botcheck"
          class="hidden"
          style="display:none"
          tabindex="-1"
          autocomplete="off"
        />

        <!-- Hidden fields -->
        <input
          type="hidden"
          name="access_key"
          value="bcb9ab4c-1f93-4fcb-ab0f-ec7f30630642"
        />
        <input
          type="hidden"
          name="subject"
          value="New inquiry from 9th Hour website"
        />

        <!-- Name -->
        <div>
          <label
            for="contact-name"
            class="block text-sm font-medium text-gray-700 dark:text-zinc-300 mb-1.5"
            >Name</label
          >
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-white/30 focus:border-transparent transition-all"
            placeholder="Your name"
          />
        </div>

        <!-- Email -->
        <div>
          <label
            for="contact-email"
            class="block text-sm font-medium text-gray-700 dark:text-zinc-300 mb-1.5"
            >Email</label
          >
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-white/30 focus:border-transparent transition-all"
            placeholder="you@company.com"
          />
        </div>

        <!-- Message -->
        <div>
          <label
            for="contact-message"
            class="block text-sm font-medium text-gray-700 dark:text-zinc-300 mb-1.5"
            >Message</label
          >
          <textarea
            id="contact-message"
            name="message"
            required
            rows="4"
            class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-gray-900 dark:focus:ring-white/30 focus:border-transparent transition-all resize-none"
            placeholder="What's stuck? What have you tried? What does success look like?"
          ></textarea>
        </div>

        <!-- Submit button -->
        <button
          type="submit"
          id="contact-submit"
          class="w-full bg-gray-900 text-white dark:bg-white dark:text-black py-3.5 rounded-full text-base font-bold hover:bg-black dark:hover:bg-zinc-200 transition-all flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="submit-text">Send message</span>
          <svg
            id="submit-spinner"
            class="hidden animate-spin w-5 h-5"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle
              class="opacity-25"
              cx="12"
              cy="12"
              r="10"
              stroke="currentColor"
              stroke-width="4"></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </button>
      </form>

      <!-- Success state -->
      <div id="contact-success" class="hidden p-6 text-center py-12">
        <div
          class="w-16 h-16 rounded-full bg-gray-100 dark:bg-white/5 flex items-center justify-center mx-auto mb-4"
        >
          <CheckCircle2 class="w-8 h-8 text-gray-900 dark:text-white" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
          Message sent.
        </h3>
        <p class="text-gray-500 dark:text-zinc-400 mb-6">
          I'll get back to you within 24 hours.
        </p>
        <button
          id="contact-success-close"
          class="text-sm font-medium text-gray-500 dark:text-zinc-400 hover:text-gray-900 dark:hover:text-white transition-colors underline underline-offset-4"
        >
          Close
        </button>
      </div>

      <!-- Error state -->
      <div id="contact-error" class="hidden p-6 text-center py-12">
        <div
          class="w-16 h-16 rounded-full bg-red-50 dark:bg-red-500/10 flex items-center justify-center mx-auto mb-4"
        >
          <XCircle class="w-8 h-8 text-red-500" />
        </div>
        <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
          Something went wrong.
        </h3>
        <p class="text-gray-500 dark:text-zinc-400 mb-6">
          Please try again or email me directly.
        </p>
        <button
          id="contact-error-retry"
          class="text-sm font-medium text-gray-500 dark:text-zinc-400 hover:text-gray-900 dark:hover:text-white transition-colors underline underline-offset-4"
        >
          Try again
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  const modal = document.getElementById("contact-modal")!;
  const backdrop = document.getElementById("contact-modal-backdrop")!;
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const closeBtn = document.getElementById("contact-modal-close")!;
  const successView = document.getElementById("contact-success")!;
  const errorView = document.getElementById("contact-error")!;
  const successCloseBtn = document.getElementById("contact-success-close")!;
  const errorRetryBtn = document.getElementById("contact-error-retry")!;
  const submitBtn = document.getElementById(
    "contact-submit",
  ) as HTMLButtonElement;
  const submitText = document.getElementById("submit-text")!;
  const submitSpinner = document.getElementById("submit-spinner")!;

  let previouslyFocusedElement: HTMLElement | null = null;
  let scrollY = 0;

  function openModal() {
    previouslyFocusedElement = document.activeElement as HTMLElement;
    scrollY = window.scrollY;
    document.body.style.position = "fixed";
    document.body.style.top = `-${scrollY}px`;
    document.body.style.width = "100%";

    modal.classList.remove("hidden");
    modal.classList.remove("modal-closing");
    modal.classList.add("modal-open");

    setTimeout(() => {
      (document.getElementById("contact-name") as HTMLInputElement)?.focus();
    }, 100);
  }

  function closeModal() {
    modal.classList.remove("modal-open");
    modal.classList.add("modal-closing");

    document.body.style.position = "";
    document.body.style.top = "";
    document.body.style.width = "";
    window.scrollTo(0, scrollY);

    setTimeout(() => {
      modal.classList.add("hidden");
      modal.classList.remove("modal-closing");
      resetFormView();
      previouslyFocusedElement?.focus();
    }, 150);
  }

  function resetFormView() {
    form.classList.remove("hidden");
    successView.classList.add("hidden");
    errorView.classList.add("hidden");
    form.reset();
    submitBtn.disabled = false;
    submitText.classList.remove("hidden");
    submitSpinner.classList.add("hidden");
  }

  // Open triggers
  document.querySelectorAll("[data-open-contact]").forEach((el) => {
    el.addEventListener("click", openModal);
  });

  // Close triggers
  closeBtn.addEventListener("click", closeModal);
  backdrop.addEventListener("click", closeModal);
  successCloseBtn.addEventListener("click", closeModal);

  // ESC key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal.classList.contains("hidden")) {
      closeModal();
    }
  });

  // Focus trap
  modal.addEventListener("keydown", (e) => {
    if (e.key !== "Tab") return;
    const focusableElements = modal.querySelectorAll<HTMLElement>(
      'button:not([disabled]), input:not([type="hidden"]):not([tabindex="-1"]), textarea, [tabindex]:not([tabindex="-1"])',
    );
    const first = focusableElements[0];
    const last = focusableElements[focusableElements.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last?.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first?.focus();
    }
  });

  // Error retry
  errorRetryBtn.addEventListener("click", () => {
    errorView.classList.add("hidden");
    form.classList.remove("hidden");
  });

  // Form submission
  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    submitBtn.disabled = true;
    submitText.classList.add("hidden");
    submitSpinner.classList.remove("hidden");

    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        form.classList.add("hidden");
        successView.classList.remove("hidden");
      } else {
        throw new Error(result.message || "Submission failed");
      }
    } catch {
      form.classList.add("hidden");
      errorView.classList.remove("hidden");
    }
  });
</script>
